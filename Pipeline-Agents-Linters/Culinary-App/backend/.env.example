# Skopiuj do pliku .env i uzupełnij (nie commituj .env)

OPENAI_API_KEY=
JWT_SECRET=
# Długi losowy sekret, np.: openssl rand -hex 32

# Opcjonalnie: wspólny sekret serwera (pepper) — przed bcrypt stosowany jest HMAC-SHA256(pepper, password).
# Po ustawieniu: nowe rejestracje i uaktualnienia przy logowaniu używają tego schematu; stare hasła (bcrypt jawny) nadal działają przy logowaniu i są automatycznie przeliczane.
PASSWORD_PEPPER=

# Opcjonalnie: production — wymusza wyjątek przy starcie, jeśli JWT_SECRET jest domyślny / zbyt krótki
# ENV=production

# Opcjonalnie: ścieżka do folderu raportów pipeline (względem katalogu backend/)
# RAPORTS_DIR=../../Pipeline-Agents/raports
